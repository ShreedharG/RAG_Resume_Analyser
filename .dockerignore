# ──────────────────────────────────────────────
# .dockerignore — Keeps build context lean
# ──────────────────────────────────────────────

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Node
frontend/node_modules/
frontend/.cache/

# Runtime data (handled by Docker volume)
backend/data/

# Git
.git/
.gitignore

# Secrets — NEVER bake into images
.env

# Editor/OS
.vscode/
.idea/
*.DS_Store
Thumbs.db

# Test artifacts
test/
